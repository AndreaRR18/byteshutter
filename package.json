{
  "name": "byteshutter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "cd public_html && npm test",
    "convert": "npx tsx scripts/ConvertArticlesToJSON/convertArticlesToJson.ts",
    "dev": "cd public_html && npm run dev",
    "build": "npx tsx scripts/ConvertArticlesToJSON/convertArticlesToJson.ts && cd public_html && npm run build",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "lint:html": "eslint public_html/ --ext .ts,.js",
    "preview": "npx tsx scripts/ConvertArticlesToJSON/convertArticlesToJson.ts && cd public_html && npm run preview",
    "deploy": "npm run build && cd public_html && npm run deploy"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",

    "@types/node": "^22.15.30",

    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",


    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",

    "eslint-plugin-prettier": "^5.5.5",


    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^7.2.4",
    "vitest": "^3.1.4"
  }
}
