{
  "name": "byteshutter-html",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "ByteShutter website - HTML/CSS version",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:optimized": "vite build && npx tsx scripts/optimizePerformance.ts",
    "preview": "vite preview",
    "optimize": "npx tsx scripts/optimizePerformance.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "clean-css": "^5.3.2",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "html-minifier": "^4.0.0",
    "jsdom": "^22.0.0",
    "lint-staged": "^13.0.0",
    "prettier": "^3.0.0",
    "terser": "^5.19.0",
    "vite": "^7.2.4",
    "vitest": "^0.30.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,md}": [
      "prettier --write"
    ]
  }
}
